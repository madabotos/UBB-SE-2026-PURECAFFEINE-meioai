<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Property_and_Management.src.Views.RequestsToOthersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Property_and_Management.src.DTO"
      xmlns:converters="using:Property_and_Management.src.Utilities"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Page.Resources>
        <converters:ByteArrayToImageConverter x:Key="ImageConverter"/>
        <BitmapImage x:Key="DefaultGameImage" UriSource="ms-appx:///Assets/default-game-placeholder.jpg"/>
        <Style TargetType="ListViewItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="My Requests" Style="{StaticResource SubtitleTextBlockStyle}" Margin="12"/>

        <!-- ListView for requests [REQ-REQ-05] -->
        <ListView x:Name="ItemsListView" Grid.Row="1"
                  ItemsSource="{Binding PagedRequests}"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  DoubleTapped="RequestItem_Tapped">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:RequestDTO">
                    <Grid Tapped="RequestItem_Tapped" Background="#2D2D2D" Margin="0,0,0,10" Padding="15" CornerRadius="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Game picture [REQ-REQ-05] -->
                        <Image Grid.Column="0" Source="{Binding Game.Image, Converter={StaticResource ImageConverter}}"
                               Width="72" Height="72" Stretch="UniformToFill"
                               ImageFailed="Image_ImageFailed">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Source" Value="{StaticResource DefaultGameImage}"/>
                                </Style>
                            </Image.Style>
                        </Image>

                        <!-- Game name, owner name, dates [REQ-REQ-05] -->
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="{Binding Game.Name}" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Owner.DisplayName}" Style="{StaticResource BodyTextBlockStyle}" Opacity="0.8"/>
                            <TextBlock Text="{Binding StartDateDisplayLong}" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock Text="{Binding EndDateDisplayLong}" Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>

                        <!-- Cancel button [REQ-REQ-06] -->
                        <Button Grid.Column="2"
                                Content="Cancel"
                                Tag="{Binding Id}"
                                Click="CancelButton_Click"
                                Tapped="CancelButton_Tapped"
                                Margin="8,0,0,0"
                                Background="#C50F1F"
                                Foreground="White"
                                VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Paging -->
        <Grid Grid.Row="2" Margin="12">
            <TextBlock Text="{Binding ShowingText}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Previous" Click="PrevButton_Click" Margin="4"/>
                <TextBlock Text="{Binding CurrentPage}" VerticalAlignment="Center" Margin="12,0"/>
                <TextBlock Text="/" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding PageCount}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="Next" Click="NextButton_Click" Margin="4"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
