<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Property_and_Management.src.Views.RequestsFromOthersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Property_and_Management.src.DTO"
            xmlns:converters="using:Property_and_Management.src.Utilities"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Page.Resources>
                <converters:ByteArrayToImageConverter x:Key="ImageConverter"/>
        <BitmapImage x:Key="DefaultGameImage" UriSource="ms-appx:///Assets/default-game-placeholder.jpg"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header [UI-ORQ-02] info  -->
        <TextBlock Grid.Row="0" Text="{Binding ShowingText}" Style="{StaticResource SubtitleTextBlockStyle}" Margin="12"/>

        <!-- ListView for requests [UI-ORQ-01,02,03] -->
        <ListView x:Name="ItemsListView" Grid.Row="1" 
                  ItemsSource="{Binding PagedRequests}"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  DoubleTapped="RequestItem_Tapped">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:RequestDTO">
                    <Grid Tapped="RequestItem_Tapped" Padding="12" Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Game picture or placeholder [UI-ORQ-02] -->
                           <Image Grid.Column="0" Source="{Binding Game.Image, Converter={StaticResource ImageConverter}}" 
                               Width="72" Height="72" Stretch="UniformToFill"
                               ImageFailed="Image_ImageFailed">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Source" Value="{StaticResource DefaultGameImage}"/>
                                </Style>
                            </Image.Style>
                        </Image>
                        <!-- Game name, renter, dates [UI-ORQ-02] -->
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="{Binding Game.Name}" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Renter.DisplayName}" Style="{StaticResource BodyTextBlockStyle}" Opacity="0.8"/>
                            <TextBlock Text="{Binding StartDateDisplayLong}" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock Text="{Binding EndDateDisplayLong}" Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Paging and Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="12">
            <Button Content="Previous" Click="PrevButton_Click" Margin="4"/>
            <TextBlock Text="{Binding CurrentPage}" VerticalAlignment="Center" Margin="12,0"/>
            <TextBlock Text="/" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding PageCount}" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Button Content="Next" Click="NextButton_Click" Margin="4"/>
            <!-- Approve/Deny buttons can be per-item or bulk -->
        </StackPanel>
    </Grid>
</Page>
