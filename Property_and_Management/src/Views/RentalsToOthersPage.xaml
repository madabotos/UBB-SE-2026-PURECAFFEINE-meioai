<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Property_and_Management.Src.Views.RentalsToOthersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Property_and_Management.Src.DataTransferObjects"
      xmlns:converters="using:Property_and_Management.Src.Utilities"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Page.Resources>
        <converters:ByteArrayToImageConverter x:Key="ImageConverter"/>
        <converters:BooleanToOpacityConverter x:Key="BooleanToOpacityConverter"/>
        <BitmapImage x:Key="DefaultGameImage" UriSource="ms-appx:///Assets/default-game-placeholder.jpg"/>
        <Style TargetType="ListViewItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="12">
            <TextBlock Text="My Rentals" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center"/>
            
        </Grid>

        <ListView x:Name="ItemsListView" Grid.Row="1"
                  ItemsSource="{Binding PagedItems}"
                  SelectionMode="None"
                  IsItemClickEnabled="False">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:RentalDataTransferObject">
                    <Grid Background="#2D2D2D"
                          Margin="0,0,0,10"
                          Padding="15"
                          CornerRadius="8"
                          Opacity="{Binding IsExpired, Converter={StaticResource BooleanToOpacityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image Grid.Column="0" Source="{Binding Game.Image, Converter={StaticResource ImageConverter}}"
                               Width="72" Height="72" Stretch="UniformToFill"
                               ImageFailed="Image_ImageFailed">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Source" Value="{StaticResource DefaultGameImage}"/>
                                </Style>
                            </Image.Style>
                        </Image>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="{Binding Game.Name}" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Renter.DisplayName}" Style="{StaticResource BodyTextBlockStyle}" Opacity="0.8"/>
                            <TextBlock Text="{Binding StartDateDisplayLong}" Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock Text="{Binding EndDateDisplayLong}" Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Paging -->
        <Grid Grid.Row="2" Margin="12">
            <TextBlock Text="{Binding ShowingText}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Previous" Click="PrevButton_Click" Margin="4"/>
                <TextBlock Text="{Binding CurrentPage}" VerticalAlignment="Center" Margin="12,0"/>
                <TextBlock Text="/" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding PageCount}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="Next" Click="NextButton_Click" Margin="4"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
