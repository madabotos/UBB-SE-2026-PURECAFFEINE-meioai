<Page
    x:Class="Property_and_Management.src.Views.ListingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Property_and_Management.src.Utilities"
    Background="#1E1E1E">

    <Page.Resources>
        <converters:ByteArrayToImageConverter x:Key="ImageConverter" />
    </Page.Resources>

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="My Listings" FontSize="28" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="+ Create Game" HorizontalAlignment="Right" Style="{StaticResource AccentButtonStyle}" Click="CreateGameButton_Click"/>
        </Grid>

        <ListView Grid.Row="1" ItemsSource="{Binding PagedListings}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Background="#2D2D2D" Margin="0,0,0,10" Padding="15" CornerRadius="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Image Grid.Column="0" Source="{Binding Image, Converter={StaticResource ImageConverter}}" 
                               Width="80" Height="80" Stretch="UniformToFill" HorizontalAlignment="Left"/>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="{Binding Description}" Foreground="#CCCCCC" TextWrapping="WrapWholeWords" MaxHeight="40" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Edit" Margin="0,0,10,0" Click="EditGameButton_Click" Tag="{Binding}"/>
                            <Button Content="Delete" Background="#C50F1F" Foreground="White" Click="DeleteGameButton_Click" Tag="{Binding}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="2" Margin="12,20,12,0">
            <TextBlock Text="{Binding ShowingText}" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="#CCCCCC"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Prev" Click="PrevButton_Click" Margin="4"/>
                <TextBlock Text="{Binding CurrentPage}" VerticalAlignment="Center" Margin="12,0" Foreground="White"/>
                <TextBlock Text="/" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="White"/>
                <TextBlock Text="{Binding PageCount}" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="White"/>
                <Button Content="Next" Click="NextButton_Click" Margin="4"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
