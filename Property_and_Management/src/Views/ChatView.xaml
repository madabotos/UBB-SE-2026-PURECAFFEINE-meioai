<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Property_and_Management.src.Views.ChatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
            <TextBlock Text="Mock Chat Page" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>

            <Border Background="LightGray" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                <TextBlock Text="Renter: Hello! I would love to rent your board game for the weekend. Is it available?" 
                           TextWrapping="Wrap" MaxWidth="400" FontSize="16"/>
            </Border>

            <TextBlock x:Name="ActionPromptText" Text="Choose an action for this request:" HorizontalAlignment="Center" FontSize="16"/>

            <StackPanel x:Name="ActionButtonsPanel" Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center">
                <Button Content="Approve" 
                        Click="ApproveButton_Click" 
                        Background="DarkGreen" 
                        Foreground="White" 
                        Width="120" Height="40"/>

                <Button Content="Deny" 
                        Click="DenyButton_Click" 
                        Background="DarkRed" 
                        Foreground="White" 
                        Width="120" Height="40"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
