# ==========================================
# WinUI 3 / Windows App SDK Specific
# ==========================================
# App package directories generated during MSIX builds
AppPackages/
BundleArtifacts/
Packages.dgml

# XAML compiler generated files (usually in obj/, but sometimes leak out depending on config)
Generated\ Files/
GeneratedFiles/

# Temporary files created during MSIX packaging
_pkginfo.txt
*.appx
*.appxbundle
*.msix
*.msixbundle
*.appxsym
*.appxupload
*.msixupload

# ==========================================
# NuGet Packages
# ==========================================
*.nupkg
# The packages folder can be ignored because NuGet restores them automatically
[Pp]ackages/
!/[Pp]ackages/build/
# If you use local NuGet caching
.nuget/

