<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Property_and_Management.Src.Views.NotificationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Property_and_Management.Src.Views"
      xmlns:converters="using:Property_and_Management.Src.Utilities"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:notificationDtoNamespace="using:Property_and_Management.Src.DataTransferObjects"
      mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style TargetType="ListViewItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="My Notifications" Style="{StaticResource SubtitleTextBlockStyle}" Margin="12"/>

        <ListView x:Name="ItemsListView" Grid.Row="1"
                  ItemsSource="{Binding PagedItems}"
                  SelectionMode="None"
                  IsItemClickEnabled="False">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="notificationDtoNamespace:NotificationDataTransferObject">
                    <Grid Background="#2D2D2D" Margin="0,0,0,10" Padding="15" CornerRadius="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Width="72" Height="72" Background="#3D3D3D" CornerRadius="36">
                            <FontIcon Glyph="&#xE7ED;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Title}" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind Body}" Style="{StaticResource BodyTextBlockStyle}" Opacity="0.8" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="{x:Bind TimeDisplay}" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,4,0,0" Opacity="0.6"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <!-- Offer actions: only visible for OfferReceived notifications. -->
                            <StackPanel Orientation="Horizontal" Spacing="6"
                                        Visibility="{x:Bind IsActionable, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button Content="Approve"
                                        Click="ApproveOfferButton_Click"
                                        Background="#107C10"
                                        Foreground="White"/>
                                <Button Content="Deny"
                                        Click="DenyOfferButton_Click"
                                        Background="#C50F1F"
                                        Foreground="White"/>
                            </StackPanel>
                            <Button Click="DeleteButton_Click"
                                    ToolTipService.ToolTip="Delete"
                                    Margin="12,0,0,0"
                                    Width="40" Height="40"
                                    Background="#C50F1F"
                                    Foreground="White"
                                    BorderThickness="0">
                                <SymbolIcon Symbol="Delete" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="2" Margin="12">
            <TextBlock Text="{Binding ShowingText}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Previous" Click="PrevButton_Click" Margin="4"/>
                <TextBlock Text="{Binding CurrentPage}" VerticalAlignment="Center" Margin="12,0"/>
                <TextBlock Text="/" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding PageCount}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="Next" Click="NextButton_Click" Margin="4"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
