<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Property_and_Management.Src.Views.CreateRequestView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Width="400" HorizontalAlignment="Center" Spacing="15" Margin="0,40,0,40">
            <TextBlock Text="Create New Request" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>

            <ComboBox x:Name="GamePicker"
                      Header="Select a Game*"
                      HorizontalAlignment="Stretch"
                      DisplayMemberPath="Name"
                      SelectionChanged="GamePicker_SelectionChanged"/>

            <CalendarDatePicker x:Name="StartDatePicker"
                                Header="Start Date*"
                                HorizontalAlignment="Stretch"/>

            <CalendarDatePicker x:Name="EndDatePicker"
                                Header="End Date*"
                                HorizontalAlignment="Stretch"/>

            <Button Content="Submit Request" Click="SaveButton_Click" Background="DarkBlue" Foreground="White"
                    HorizontalAlignment="Stretch" Height="40" Margin="0,20,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Page>
