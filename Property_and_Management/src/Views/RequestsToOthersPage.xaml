<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Property_and_Management.src.Views.RequestsToOthersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Property_and_Management.src.Views"
      xmlns:dto="using:Property_and_Management.src.DTO"
      mc:Ignorable="d">

    <Grid Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="My Requests" FontSize="20" FontWeight="Bold"/>
        </StackPanel>

        <!-- Table header -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid ColumnDefinitions="80,*,180,150,80" Background="#F6F6F6" Padding="8" Grid.Row="0">
                <TextBlock Grid.Column="0" Text="Game" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Seller" FontWeight="Bold"/>
                <TextBlock Grid.Column="2" Text="Dates" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="Status" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="Action" FontWeight="Bold" HorizontalAlignment="Center"/>
            </Grid>

            <!-- Items -->
            <ItemsControl x:Name="ItemsListView" Grid.Row="1" ItemsSource="{Binding PagedRequests}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="dto:RequestDTO">
                        <Grid ColumnDefinitions="80,*,180,150,80" Padding="12" BorderBrush="#EEE" BorderThickness="0,0,0,1"
                              Tapped="RequestItem_Tapped">

                            <!-- Game Picture - Placeholder (add byte[] converter later) -->
                            <Image Grid.Column="0" Source="ms-appx:///Assets/placeholder_game.png" 
                                   Stretch="UniformToFill" VerticalAlignment="Center"/>

                            <!-- Seller + Game Name -->
                            <StackPanel Grid.Column="1" Margin="12,0">
                                <TextBlock Text="{x:Bind Game.Owner.DisplayName}" FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{x:Bind Game.Name}" FontSize="14" Foreground="Gray" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <!-- Dates -->
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind StartDate, StringFormat='{0:dd/MM}'}" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind EndDate, StringFormat='{0:dd/MM}'}"/>
                            </StackPanel>

                            <!-- Status -->
                            <TextBlock Grid.Column="3" Text="Pending" Foreground="Orange" FontWeight="SemiBold" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <!-- Cancel Button -->
                            <Button Grid.Column="4" Click="CancelButton_Click" Background="LightCoral" Foreground="White" 
                                    FontWeight="Bold" Content="✕ Cancel" Padding="12,6" 
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- Pagination -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding ShowingText}"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Prev" Click="PrevButton_Click"/>
                <TextBlock VerticalAlignment="Center" Text="{Binding CurrentPage}"/>
                <TextBlock VerticalAlignment="Center" Text="/"/>
                <TextBlock VerticalAlignment="Center" Text="{Binding PageCount}"/>
                <Button Content="Next" Click="NextButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
